# ============================================================================
# Flask Configuration
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=false

# ============================================================================
# Database Configuration (Neon PostgreSQL)
# ============================================================================
# You can either provide a single complete connection string:
DATABASE_URL=postgresql://user:password@ep-cool-water-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# OR provide individual database parameters:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=supply_chain_db
DB_SSLMODE=require

# ============================================================================
# JWT Authentication Security Key
# ============================================================================
JWT_SECRET_KEY=super-secret-key-change-in-production

# ============================================================================
# CORS Access Control
# ============================================================================
# Comma-separated list of allowed frontend URLs (e.g. Netlify domain)
ALLOWED_ORIGINS=http://localhost:5173,https://your-app-name.netlify.app
